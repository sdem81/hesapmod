{
  "name": "hesapmod",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "mobile:android": "powershell -ExecutionPolicy Bypass -File ./mobile/scripts/start-android-simulator.ps1 -Clear",
    "mobile:android:no-clear": "powershell -ExecutionPolicy Bypass -File ./mobile/scripts/start-android-simulator.ps1",
    "analyze:coverage": "tsx scripts/analyze-calculator-coverage.ts",
    "export:index-priority": "tsx scripts/generate-index-priority.ts",
    "prepare:indexnow": "npx -y tsx scripts/prepare-indexnow.ts",
    "generate:runtimes": "tsx scripts/generate-runtime-modules.ts",
    "build": "npm run prepare:indexnow && npm run generate:runtimes && next build",
    "postbuild": "npx -y tsx scripts/submit-indexing.ts",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@next/third-parties": "^14.2.5",
    "autoprefixer": "^10.4.24",
    "clsx": "^2.1.1",
    "googleapis": "^171.4.0",
    "lucide-react": "^0.428.0",
    "next": "14.2.5",
    "react": "^18",
    "react-dom": "^18",
    "resend": "^6.9.3",
    "tailwind-merge": "^2.5.2"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.5",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vercel": "^50.22.1"
  }
}
