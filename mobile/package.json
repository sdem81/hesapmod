{
  "name": "hesapmod-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "powershell -ExecutionPolicy Bypass -File ./scripts/start-android-simulator.ps1 -Clear",
    "android:raw": "expo start --android",
    "android:no-clear": "powershell -ExecutionPolicy Bypass -File ./scripts/start-android-simulator.ps1",
    "android:simulator": "powershell -ExecutionPolicy Bypass -File ./scripts/start-android-simulator.ps1 -Clear",
    "android:simulator:no-clear": "powershell -ExecutionPolicy Bypass -File ./scripts/start-android-simulator.ps1",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "expo": "~55.0.5",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-native": "0.83.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20.19.4"
  },
  "private": true
}
